<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.claus.master-agent</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/python3.12</string>
        <string>-m</string>
        <string>control_room.master</string>
        <string>start</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/clauseduardpetraeus/Github repos/control-room</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PYTHONPATH</key>
        <string>/Users/clauseduardpetraeus/Github repos/control-room/src</string>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/clauseduardpetraeus/build-logs/master-agent/launchd-stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/clauseduardpetraeus/build-logs/master-agent/launchd-stderr.log</string>

    <key>ThrottleInterval</key>
    <integer>30</integer>
</dict>
</plist>
